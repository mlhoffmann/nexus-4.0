{
  "uid": "nexus-visao-geral",
  "title": "NEXUS 4.0 — Visão Geral das Operações",
  "tags": ["nexus", "producao", "oee"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "OEE Geral",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT AVG(oee_pct) AS \"OEE\" FROM equipment WHERE status != 'offline'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 65 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Equipamentos por Status",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT status, COUNT(*) AS total FROM equipment GROUP BY status",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ordens de Produção — Progresso",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT id AS \"OP\", progress_pct AS \"Progresso\" FROM production_orders WHERE status != 'completed' ORDER BY priority DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Alertas de Agentes (últimas 24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Decisões\" FROM agent_decisions WHERE created_at > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Utilização por Equipamento",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 6 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT name AS \"Equipamento\", oee_pct AS \"OEE %\" FROM equipment ORDER BY oee_pct DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Health Score dos Equipamentos",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 10, "x": 10, "y": 6 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT name AS metric, health_score AS \"Health\" FROM equipment ORDER BY health_score ASC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Ordens de Produção",
      "type": "table",
      "gridPos": { "h": 8, "w": 20, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT po.id AS \"OP\", p.name AS \"Produto\", po.quantity AS \"Qtd\", po.line_id AS \"Linha\", po.start_date AS \"Início\", po.end_date AS \"Prazo\", po.status AS \"Status\", po.progress_pct AS \"Progresso %\", po.priority AS \"Prioridade\" FROM production_orders po JOIN products p ON po.product_id = p.id ORDER BY po.priority DESC, po.start_date",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "title": "Decisões dos Agentes (Timeline)",
      "type": "table",
      "gridPos": { "h": 8, "w": 20, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"Hora\", agent_role AS \"Agente\", decision AS \"Decisão\", confidence AS \"Confiança\", reasoning AS \"Raciocínio\" FROM agent_decisions ORDER BY created_at DESC LIMIT 20",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "title": "Automações N8N (últimas 24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 20, "x": 0, "y": 30 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"Hora\", workflow_name AS \"Workflow\", status AS \"Status\", summary AS \"Resumo\", array_to_string(agents_involved, ', ') AS \"Agentes\" FROM automation_logs WHERE created_at > NOW() - INTERVAL '24 hours' ORDER BY created_at DESC LIMIT 15",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "title": "Automações — Alertas Ativos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 38 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Alertas 24h\" FROM automation_logs WHERE status IN ('warning', 'critical') AND created_at > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Total Execuções 24h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 38 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Execuções\" FROM automation_logs WHERE created_at > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
