FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit>=1.37.0 \
    httpx>=0.27.0 \
    plotly>=5.22.0 \
    pandas>=2.2.0

COPY dashboard/ ./dashboard/

EXPOSE 8501

CMD ["streamlit", "run", "dashboard/streamlit_app.py", "--server.address", "0.0.0.0", "--server.port", "8501"]
